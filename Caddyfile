# Caddy reverse proxy for econ-newsfeed API
# Domain: econ-newsfeed.duckdns.org
# Caddy auto-provisions Let's Encrypt SSL certificates.
#
# Install: sudo apt install caddy
# Start:   sudo systemctl enable --now caddy
# Logs:    journalctl -u caddy

econ-newsfeed.duckdns.org {
	reverse_proxy localhost:8000
}
