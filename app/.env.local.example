# Backend API URL (used by the frontend for data fetching)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API URL used by Next.js rewrites (next.config.mjs).
# Inside Docker this is set automatically to http://api:8000.
# When running the frontend outside Docker, set this to the backend's local address:
API_INTERNAL_URL=http://localhost:8001
