# Database (required)
DB_HOST=localhost
DB_PORT=3306
DB_USER=econ_app
DB_PASSWORD=secret
DB_NAME=econ_newsfeed
# DB_SSL_CA=/path/to/ca-cert.pem  # Uncomment for managed cloud databases (RDS, Cloud SQL)
# DB_POOL_SIZE=10  # Per-process pool size; with 4 gunicorn workers = 40 total connections

# Docker Compose only — MySQL root password
MYSQL_ROOT_PASSWORD=rootsecret


# LLM provider: Google AI Studio (required)
# Get an API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
# Gemini model ID. Default: Gemini 2.5 Flash.
LLM_MODEL=gemma-4-31b-it

# Scraping
SCRAPE_INTERVAL_HOURS=24
SCRAPE_ON_STARTUP=false
SCRAPE_API_KEY=changeme-min-16chars
ADMIN_PASSWORD=changeme-admin-password
SCRAPE_RATE_LIMIT_SECONDS=2
CONTENT_MAX_CHARS=20000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# OpenAlex (optional — enriches papers with coauthors, abstracts)
OPENALEX_API_KEY=
OPENALEX_MAILTO=your@email.com
OPENALEX_DAILY_BUDGET=1000

# Enrichment worker (runs continuously in the API process)
ENRICHMENT_WORKER_ENABLED=false

# Production deployment
# FRONTEND_URL=https://your-app.vercel.app    # Required in prod for CORS
# WEB_CONCURRENCY=2                           # Gunicorn workers (default 2)
